# CMake & Build artifacts
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.o
*.out

# Ignore all build folders in subdirectories
*/build/
*/*/build/

# Python artifacts
__pycache__/
*.pyc

# IDEs / OS files
.vscode/
.idea/
.DS_Store

# Ignore the entire sample_data directory
# (This prevents you from uploading huge datasets and the generated plys/compressed/decompressed folders)
sample_data/

# Ignore the results text files generated by the bash scripts
bash_scripts/*_CD.txt
bash_scripts/*_PSNR.txt
bash_scripts/*.out
bash_scripts/*.log

# Depending on your preference, you may want to ignore the TMC13 source code entirely 
# if you want users to download it themselves, but if you want to include it, 
# this rule at least keeps its build artifacts out:
mpeg-pcc-tmc13-*/build/
*.zip
